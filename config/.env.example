# Discord webhook del canal donde quieres recibir alertas.
DISCORD_WEBHOOK_URL=

# Alias opcional del servidor para los mensajes.
HOSTNAME_ALIAS=

# auto | journald | authlog | secure | file
SSH_LOG_MODE=auto

# Opcional. Solo se usa para journald si quieres restringir la búsqueda a units concretos.
# Ejemplo: ssh.service,sshd.service
SSH_JOURNAL_UNIT=

# Opcional. Solo se usa si SSH_LOG_MODE=file o como fallback en modo auto.
SSH_LOG_FILE=

# Intervalo de polling en segundos.
SSH_POLL_INTERVAL=5

# Listas separadas por comas.
SSH_IGNORE_IPS=
SSH_IGNORE_USERS=

# Rate limit básico por combinación evento/usuario/IP.
SSH_RATE_LIMIT_WINDOW=60
SSH_RATE_LIMIT_BURST=10

# Rutas recomendadas para despliegue.
STATE_DIR=/var/lib/sshook
LOG_DIR=/var/log/sshook

LOG_LEVEL=INFO
